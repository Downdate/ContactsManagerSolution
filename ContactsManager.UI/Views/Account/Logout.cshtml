@{
    ViewBag.Title = "Logout";
    ViewBag.CurrentURL = Context.Request.Path;
}

<div class="text-grey mb">
    <span>Contacts</span>
    <i class="fa-solid fa-caret-right"></i>
    <span>Logout</span>
</div>

<div class="form-container logout-card">

    <div class="logout-icon">
        <i class="fa-solid fa-right-from-bracket"></i>
    </div>

    <h2 class="text-large">Log Out</h2>

    <p class="logout-message margin-bottom">
        Are you sure you want to sign out of your account?
    </p>

    <form asp-controller="Account"
          asp-action="LogoutPost"
          method="post">

        @Html.AntiForgeryToken()

        <div class="logout-buttons ul--justifyRight">

            <button type="submit" class="button-red-back">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </button>

            <a asp-controller="Persons"
               asp-action="Index"
               class="button-blue-back">
                <i class="fa-solid fa-xmark"></i>
                Cancel
            </a>

        </div>

    </form>

</div>